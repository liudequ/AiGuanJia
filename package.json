{
  "name": "aiguanjia",
  "version": "0.1.0",
  "description": "AiGuanJia desktop app bootstrap",
  "main": "dist/main/main.js",
  "scripts": {
    "pretest": "node -e \"require('node:fs').rmSync('.test-dist',{recursive:true,force:true})\"",
    "test": "tsc --module CommonJS --target ES2022 --moduleResolution Node --esModuleInterop --strict --skipLibCheck --types node --outDir .test-dist tests/smoke/app_boot.test.ts src/main/main.ts src/shared/types.ts && node --test .test-dist/tests/smoke/app_boot.test.js",
    "build": "tsc -p tsconfig.json && node -e \"const fs=require('node:fs');fs.mkdirSync('dist/renderer',{recursive:true});fs.copyFileSync('src/renderer/index.html','dist/renderer/index.html');\"",
    "start": "npm run build && electron ."
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.20",
    "electron": "^36.3.2",
    "typescript": "^5.8.3"
  }
}
